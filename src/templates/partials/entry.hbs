<div class="pure-g">
  <div class="pure-u-1 pure-u-md-1-6">
    <p class="date">
      {{date.from}} – {{date.to}}
    </p>
  </div>
  <div class="pure-u-1 pure-u-md-5-6">
    <div class="pure-g">
      <div class="pure-u-2-3">
        <p>{{#emphasize-first}}{{position.name}}{{/emphasize-first}}</p>
      </div>
      <div class="pure-u-1-3 remark">
        <p>
          <a href="{{position.link}}">
            {{position.company}}
          </a>, {{position.location}}
        </p>
      </div>
    </div>
    {{partial text}}
  </div>
</div>
